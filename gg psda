* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}
body {
  height: 2800px;
  background-color: black;
}

.final {
  display: flex;
  width: 100%;
  height: auto;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.HeroImage {
  width: 1440px;
  height: 773px;
  background-image: url(./img-bg/bg1.png);
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}

nav {
  width: 1204px;
  height: 43.5px;
  flex-shrink: 0;
  /* background-color: lightblue; */
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30px;
}

.ActionContainer {
  display: flex;
}

.actioncontainer {
  display: flex;
  gap: 24px;
}

.actioncontainer p {
  color: #fff;
  text-align: center;
  font-family: Inter;
  font-size: 18px;
  font-style: normal;
  font-weight: 600;
  line-height: normal;
  text-transform: capitalize;
}

.PinetourLogo {
  width: 101px;
  height: 35px;
}

.Language {
  width: 40px;
  height: 40px;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24px;
}

.Language p {
  color: #000;
  text-align: center;
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 600;
  line-height: normal;
  text-transform: uppercase;
}

.TextContainer {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 618px;
  height: 394px;
  /* background-color: lightpink; */
  margin-top: 135px;
}

.text1 {
  align-self: stretch;

  color: rgba(232, 237, 242, 0.72);
  text-align: center;
  font-family: "Bebas Neue";
  font-size: 80px;
  font-style: normal;
  font-weight: 400;
  line-height: 100%; /* 80px */
  text-transform: uppercase;
}

.text2 {
  color: rgba(253, 253, 254, 0.98);
  -webkit-text-stroke-width: 2px;
  -webkit-text-stroke-color: #fdfdfe;
  font-family: "Bebas Neue";
  font-size: 250px;
  font-style: normal;
  font-weight: 400;
  line-height: 100%; /* 250px */
}

.text3 {
  color: rgba(255, 255, 255, 0.8);
  font-family: Hanuman;
  font-size: 64px;
  font-style: normal;
  font-weight: 900;
  line-height: 100%; /* 64px */
}

.LocationContainer {
  width: 1440px;
  height: 500px;
  background-image: url(./img-bg/bg2.png);
  display: flex;
  justify-content: center;
  align-items: center;
  align-self: stretch;
  padding: 65px 119px;
}

.CardContainer {
  display: flex;
  width: 1202px;
  height: 375px;
  padding: var(--spacing-0, 0px) 0px;
  justify-content: center;
  align-items: center;
  gap: 40px;
  /* background-color: lightcoral; */
}

.card {
  border-radius: 40px;
  box-shadow: -8px -8px 0px 0px rgba(31, 114, 170, 0.46),
    8px 8px 0px 0px rgba(41, 114, 139, 0.25);
  position: relative;
}

.card img {
  width: 275px;
  height: 375px;
  border-radius: 40px;
  background: linear-gradient(
      0deg,
      rgba(34, 34, 34, 0.03) 0%,
      rgba(34, 34, 34, 0.03) 100%
    ),
    linear-gradient(
      0deg,
      rgba(157, 184, 218, 0.2) 0%,
      rgba(157, 184, 218, 0.2) 100%
    ),
    url(<path-to-image>) lightgray -207.022px 0px / 321.45% 128.429% no-repeat;
}

.card p {
  color: rgba(253, 253, 254, 0.8);
  text-align: center;
  text-shadow: 0px 4px 4.9px rgba(0, 0, 0, 0.65);
  font-family: "Bebas Neue";
  font-size: 37px;
  font-style: normal;
  font-weight: 400;
  line-height: normal;
  text-transform: uppercase;
  z-index: 2;
}

.Frame175 {
  position: absolute;
  /* background-color: lightblue; */
  width: 275px;
  height: 375px;
  top: 0;
  border-radius: 40px;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fdfdfe;
}

.Rectangle {
  position: absolute;
  background-color: #000;
  opacity: 0;
  transition: 1s;
  width: 275px;
  height: 375px;
  border-radius: 40px;
  top: 0;
  z-index: 1;
}

.Rectangle:hover {
  opacity: 0.3;
  transition: 0.6s;
}

.RoadmapContainer {
